---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const pageDesc =
	'中学受験国語の読解・記述・選択肢問題の解法から、教材選び・志望校別の出題傾向まで。国語先生.COMブログの全記事一覧です。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`ブログ記事一覧｜${SITE_TITLE}`} description={pageDesc} />
	</head>
	<body>
		<Header />
		<section class="hero" id="content">
			<div class="hero-copy">
				<p class="eyebrow">記事一覧</p>
				<h1>ブログ記事一覧</h1>
				<p class="hero-lead">中学受験国語の解法・勉強法・志望校の出題傾向をまとめています。</p>
			</div>
		</section>
		<main>
			<section class="section">
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a class="post-card" href={`/blog/${post.id}/`}>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2>{post.data.title}</h2>
									<p class="excerpt">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
