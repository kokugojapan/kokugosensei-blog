#!/usr/bin/env bash
# Pre-commit safeguard for kokugosensei-blog
# Blocks commits containing secrets, personal info, or blocked names.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FAIL=0
report() {
  echo ""
  echo "  pre-commit BLOCKED: $1"
  echo "  file:    $2"
  echo "  pattern: $3"
  FAIL=1
}

# 1) API keys / tokens
SECRET_PATTERNS=(
  'sk-[A-Za-z0-9]{20,}'
  'sk-ant-[A-Za-z0-9_-]{20,}'
  'ghp_[A-Za-z0-9]{20,}'
  'ghs_[A-Za-z0-9]{20,}'
  'gho_[A-Za-z0-9]{20,}'
  'github_pat_[A-Za-z0-9_]{20,}'
  'AIza[0-9A-Za-z_-]{30,}'
  'xox[baprs]-[A-Za-z0-9-]{10,}'
  'AKIA[0-9A-Z]{16}'
  '-----BEGIN [A-Z ]*PRIVATE KEY-----'
)

# 2) Personal info patterns
# Phone (Japan)
PHONE_PATTERN='0[0-9]{1,4}-[0-9]{1,4}-[0-9]{4}'
# Email except the one allowed
EMAIL_PATTERN='[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}'
ALLOWED_EMAILS='contact@kokugosensei.com|noreply@anthropic.com'

# 3) Blocked names (loaded from local file - gitignored)
BLOCKED_NAMES_FILE="$REPO_ROOT/.githooks/blocked_names.local.txt"

for FILE in $STAGED_FILES; do
  # Skip binary files & lock files
  case "$FILE" in
    *.lock|*.png|*.jpg|*.jpeg|*.gif|*.webp|*.woff|*.woff2|*.ttf|*.ico|*.pdf)
      continue ;;
  esac
  [ -f "$FILE" ] || continue

  # 1) Secrets
  for P in "${SECRET_PATTERNS[@]}"; do
    MATCH=$(grep -nE "$P" "$FILE" 2>/dev/null | head -1 || true)
    if [ -n "$MATCH" ]; then
      report "secret/API key detected" "$FILE" "$P"
      echo "  match:   $MATCH"
    fi
  done

  # 2) Phone numbers
  MATCH=$(grep -nE "$PHONE_PATTERN" "$FILE" 2>/dev/null | head -1 || true)
  if [ -n "$MATCH" ]; then
    report "phone number detected" "$FILE" "$PHONE_PATTERN"
    echo "  match:   $MATCH"
  fi

  # 3) Unknown email addresses
  MATCHES=$(grep -oE "$EMAIL_PATTERN" "$FILE" 2>/dev/null | grep -vE "$ALLOWED_EMAILS" || true)
  if [ -n "$MATCHES" ]; then
    report "unknown email address detected" "$FILE" "$EMAIL_PATTERN"
    echo "  matches:"
    echo "$MATCHES" | sed 's/^/    /'
  fi

  # 4) Blocked names from local file
  if [ -f "$BLOCKED_NAMES_FILE" ]; then
    while IFS= read -r NAME || [ -n "$NAME" ]; do
      [ -z "$NAME" ] && continue
      case "$NAME" in \#*) continue ;; esac
      if grep -qF "$NAME" "$FILE" 2>/dev/null; then
        report "blocked name detected (from blocked_names.local.txt)" "$FILE" "$NAME"
      fi
    done < "$BLOCKED_NAMES_FILE"
  fi

  # 5) Caregiver tone (per memory: feedback_no-parent-customer-tone)
  CAREGIVER_PATTERN='お子さ[んま]|保護者の[皆様方]|ご家庭で|ご両親に'
  MATCH=$(grep -nE "$CAREGIVER_PATTERN" "$FILE" 2>/dev/null | head -1 || true)
  if [ -n "$MATCH" ]; then
    echo ""
    echo "  pre-commit WARNING: caregiver tone detected (not blocked, just flagged)"
    echo "  file:    $FILE"
    echo "  match:   $MATCH"
    echo "  hint:    public blog may use this tone intentionally — verify it's appropriate"
  fi
done

if [ "$FAIL" -ne 0 ]; then
  echo ""
  echo "Commit aborted. Fix the issues above or use 'git commit --no-verify' only after reviewing."
  exit 1
fi

exit 0
